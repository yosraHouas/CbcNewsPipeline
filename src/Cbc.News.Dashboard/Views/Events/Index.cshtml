@model List<Cbc.News.Contracts.Model.PipelineEvent>

@{
    Layout = "_Layout";
}



<div class="container py-4" style="min-height:75vh;">

        <h2 class="mb-4">📊 Pipeline Events</h2>

    <table class="table table-striped table-bordered shadow">
        <thead class="table-dark">
            <tr>
                <th>Event</th>
                <th>Feed</th>
                <th>Date</th>
                <th>Message</th>
            </tr>
        </thead>

        <tbody>
            @if (!Model.Any())
            {
            <tbody>
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">No events yet.</td>
                </tr>
            </tbody>
            }
            else
            {
                @foreach (var e in Model)
                {
                    <tr>
                        <td>
                            @if (e.EventType == "IngestionCompleted")
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                            else if (e.EventType == "IngestionFailed")
                            {
                                <span class="badge bg-danger">Failed</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Started</span>
                            }
                        </td>

                        <td>@e.FeedName</td>
                        <td>@e.OccurredAtUtc.ToLocalTime()</td>
                        <td>@e.Message</td>
                    </tr>
                }}
         </tbody>
    </table>
    </div>


