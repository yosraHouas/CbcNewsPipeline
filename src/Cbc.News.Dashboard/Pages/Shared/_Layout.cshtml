@using Microsoft.AspNetCore.Http

@{
    var username = Context.Session.GetString("username");
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - CBC Dashboard</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <partial name="_Navbar" />

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1100">
        <div id="toastContainer"></div>
    </div>


    <partial name="_Footer" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

    <script src="~/js/config.js"></script>
    <script src="~/js/Notifications/navbar-notifications.js"></script>
    <script src="~/js/Notifications/navbar-notifications.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)


</body>

<script>
    let notificationCount = 0;

    function incrementNotificationsBadge() {
        const badge = document.getElementById("notificationsBadge");
        if (!badge) return;

        notificationCount++;
        badge.innerText = notificationCount;
        badge.style.display = "inline-block";
    }
</script>