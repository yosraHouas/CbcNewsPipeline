@using Microsoft.AspNetCore.Http
@{
    var role = Context.Session.GetString("role");
    var username = Context.Session.GetString("username");
    var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString("token"));
}

<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container-fluid">

        <a class="navbar-brand" asp-page="/Index">
            <i class="bi bi-speedometer2 me-2"></i> CBC Dashboard
        </a>

        <div class="navbar-nav">
            <a class="nav-link @((Context.Request.Path == "/" || Context.Request.Path == "/Index") ? "active" : "")" asp-page="/Index">
                <i class="bi bi-house-door me-1"></i> Home
            </a>

            @if (isLoggedIn)
            {
                <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Stories") ? "active" : "")" asp-page="/Stories/Index">
                    <i class="bi bi-newspaper me-1"></i> Stories
                </a>

                <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Notifications") ? "active" : "")" asp-page="/Notifications/Index">
                 <i class="bi bi-bell me-1"></i> Notifications
                 <span id="notificationsBadge" class="badge bg-danger ms-1" style="display:none;">0</span>
                </a>

                <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Events") ? "active" : "")" asp-controller="Events" asp-action="Index">
                    <i class="bi bi-clock-history me-1"></i> Historique
                </a>
            }

            @if (role == "Admin")
            {
                <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Jobs") ? "active" : "")" asp-page="/Jobs/Index">
                    <i class="bi bi-gear me-1"></i> Jobs
                </a>
            }
        </div>

        @if (isLoggedIn)
        {
            <div class="d-flex align-items-center text-white">
                <span class="badge bg-primary bg-opacity-50 rounded-pill px-3 py-2 me-3">
                    <i class="bi bi-person-circle me-1"></i>
                    Connected as @username
                </span>

                <a class="btn btn-outline-light btn-sm" asp-page="/Logout">
                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                </a>
            </div>
        }

    </div>
</nav>